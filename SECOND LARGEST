class Solution {
    public int getSecondLargest(int[] arr) {
        // code here
        int max=Integer.MIN_VALUE;
        int secondmax=Integer.MIN_VALUE;
        for(int i=0;i<arr.length;i++){
            
            if(arr[i]>max){
                secondmax=max;
                max=arr[i];
            }
            else if(arr[i]<max && arr[i]> secondmax){
                secondmax=arr[i];
            }
            
            
            
        }
        return secondmax==Integer.MIN_VALUE? -1:secondmax;
        
    }
}
